# Server Environment Configuration Template

# Server Port
PORT=5000

# Node Environment (development | production)
NODE_ENV=development

# MongoDB Connection String (MongoDB Atlas or Local Instance)
MONGODB_URI=mongodb://127.0.0.1:27017/crime-ai-db

# JWT Authentication Config
JWT_SECRET=super_secret_jwt_signature_key_change_in_production
JWT_EXPIRES_IN=8h

# Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=Example

# Client Frontend Endpoint (For CORS configuration)
CLIENT_URL=http://localhost:5173

# Zoho Catalyst Configs (If applicable for runtime environment)
CATALYST_PROJECT_ID=ksp-crime-analytics
CATALYST_PROJECT_NAME=ksp_crime_analytics
