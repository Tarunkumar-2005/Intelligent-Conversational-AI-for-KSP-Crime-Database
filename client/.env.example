# Frontend Environment Configuration Template

# API endpoint prefix. 
# In local development, we use Vite's proxy configured in vite.config.js to redirect '/api' to 'http://localhost:5000'.
# Therefore, set this to '/api/v1' to route through the local proxy.
VITE_API_URL=/api/v1

# In production (Zoho Catalyst AppSail), set this to the absolute public URL of your AppSail backend
# VITE_API_URL=https://ksp-crime-analytics-appsail-service.catalystserverless.com/api/v1
